rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Скопируйте в Firebase Console → Firestore → Rules.
    // ВНИМАНИЕ: ниже пример для разработки. Сужайте права под продакшен.

    // Резерв ников: один документ на ник (id = нижний регистр ника), только { uid }.
    // Нужен для проверки «свободен ли ник» до входа и для правил create без чтения всей users.
    match /usernames/{nameLower} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid
        && request.auth.token.email.lower() == (nameLower.lower() + '@fichat.com');
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Резерв/маппинг юзов вида $юз: public get по одному документу (id = нормализованный юз без $).
    // Нужен для поиска человека по "$юз" до чтения users.
    match /handles/{handleLower} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      match /chats/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read, create: if request.auth != null;
    }

    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      match /messages/{msgId} {
        allow read, create: if request.auth != null;
      }
    }

    match /rooms/{roomId}/messages/{msgId} {
      allow read, create: if request.auth != null;
    }
  }
}
