rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Резерв ников: один документ на ник (id = нижний регистр ника), только { uid }
    match /usernames/{nameLower} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Резерв/маппинг юзов вида $юз: public get по одному документу (id = нормализованный юз без $)
    match /handles/{handleLower} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      
      match /chats/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Личные сообщения - проверяем, что пользователь является участником чата
    match /chats/{chatId}/messages/{msgId} {
      allow read, create: if request.auth != null 
        && (request.auth.uid == chatId.split('_')[0] 
        || request.auth.uid == chatId.split('_')[1]);
    }

    // Группы - проверяем членство
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      
      // Проверяем, что пользователь является участником группы для чтения/записи сообщений
      match /messages/{msgId} {
        allow read: if request.auth != null 
          && exists(/databases/$(database)/documents/groups/$(groupId))
          && get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds.hasAny([request.auth.uid]);
        allow create: if request.auth != null 
          && exists(/databases/$(database)/documents/groups/$(groupId))
          && get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds.hasAny([request.auth.uid]);
      }
    }

    match /rooms/{roomId}/messages/{msgId} {
      allow read, create: if request.auth != null;
    }
  }
}